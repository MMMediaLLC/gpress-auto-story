# Server binding
HOST=127.0.0.1
PORT=3010

# Source feed
RSS_URL=https://gostivarpress.mk/feed/

# Public URL prefix that maps to ./public (serves /cards/*.png).
# Required for Instagram publishing because Graph API must fetch the image.
PUBLIC_BASE_URL=https://story.gostivarpress.mk

# Optional logo. If empty, the renderer uses public/logo.png,
# and if that is missing it falls back to the text "GPRESS".
LOGO_URL=

# Instagram Graph API credentials.
IG_USER_ID=
IG_ACCESS_TOKEN=

# Automatic story publishing every 10 minutes. Keep false until verified.
AUTO_PUBLISH_ENABLED=false

# Optional: override Playwright browser cache location.
# Defaults to ./.ms-playwright inside the app directory.
# PLAYWRIGHT_BROWSERS_PATH=
